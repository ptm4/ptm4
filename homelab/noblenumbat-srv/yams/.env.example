# Base configuration
PUID=1000
PGID=1000
MEDIA_DIRECTORY=/srv/media
INSTALL_DIRECTORY=/opt/yams
MEDIA_SERVICE=jellyfin

# VPN configuration — ProtonVPN free tier
# Get OpenVPN credentials from: proton.me/vpn → Account → Downloads → OpenVPN/IKEv2
VPN_ENABLED=y
VPN_SERVICE=protonvpn
VPN_USER=<your_openvpn_username>
VPN_PASSWORD=<your_openvpn_password>
