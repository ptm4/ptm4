# Copy this to .env and fill in real values
# .env is gitignored and never pushed to GitHub

MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
MYSQL_USER=bitwarden
MYSQL_DATABASE=bitwarden

VAULTWARDEN_ADMIN_TOKEN=
VAULTWARDEN_DOMAIN=https://bitwarden.rpi.lan

PIHOLE_WEB_PASSWORD=

SAMBA_USER=ptm
SAMBA_PASSWORD=

RPI_IP=

# Discord channel webhook for the daily weather bot (discord-weather container).
# Seed only — after first boot the bot's volume config is authoritative and the
# URL can be rotated from the webapp's Weather Bot tab.
DISCORD_WEBHOOK_URL=

# Discord webhooks for the other bot containers — same seed-only rule as above:
# after first boot each bot's volume config is authoritative and the URL is
# rotated from its webapp tab.
DISCORD_WEBHOOK_URL_HEALTHDIGEST=
DISCORD_WEBHOOK_URL_JELLYFIN=
DISCORD_WEBHOOK_URL_SPORTS=
DISCORD_WEBHOOK_URL_HLTV=

# Jellyfin API key for the arrivals bot — mint a dedicated key in the Jellyfin
# dashboard (Admin → API Keys) on noblenumbat. Seed only, same rule as webhooks.
JELLYFIN_API_KEY=

# opti agent dispatcher — used by the webapp for enable/disable + run-now buttons.
# DISPATCHER_URL points at the dispatcher service on opti; token must match
# HL_DISPATCH_TOKEN in opti's /etc/hl-agents.env.
DISPATCHER_URL=http://192.168.1.11:9099
HL_DISPATCH_TOKEN=
