# Copy this to .env and fill in real values
# .env is gitignored and never pushed to GitHub

MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
MYSQL_USER=bitwarden
MYSQL_DATABASE=bitwarden

VAULTWARDEN_ADMIN_TOKEN=
VAULTWARDEN_DOMAIN=https://bitwarden.rpi.lan

PIHOLE_WEB_PASSWORD=

SAMBA_USER=ptm
SAMBA_PASSWORD=

RPI_IP=

# opti agent dispatcher — used by the webapp for enable/disable + run-now buttons.
# DISPATCHER_URL points at the dispatcher service on opti; token must match
# HL_DISPATCH_TOKEN in opti's /etc/hl-agents.env.
DISPATCHER_URL=http://192.168.1.11:9099
HL_DISPATCH_TOKEN=
